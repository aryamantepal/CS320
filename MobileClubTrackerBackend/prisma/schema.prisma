// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  // Stored email is always lowercased + trimmed (see auth normalization in server.ts).
  email     String   @unique
  // bcrypt hash. NEVER store plaintext.
  password  String
  // Random opaque token issued at /login. Sent by clients as `Authorization: Bearer <token>`.
  // Null = user is not logged in on any device. Rotated on every login.
  token     String?  @unique
  imageUrl  String?
  pushToken String?
  createdAt DateTime @default(now())
  follows   Follow[]
  role          String       @default("user")
  managedOrgs   OrgManager[]
  clubRequests  ClubRequest[]
  reviewedRequests ClubRequest[] @relation("ClubRequestReviewer")
}

model Organization {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  description   String?
  imageUrl      String?
  createdAt     DateTime       @default(now())
  followers     Follow[]
  events        Event[]
  announcements Announcement[]
  managers      OrgManager[]
}

// Join table: many-to-many between User and Organization for managers.
// Composite PK (userId, organizationId): each column may repeat individually,
// only the combination must be unique. Same shape as Follow.
model OrgManager {
  userId         Int
  organizationId Int
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@id([userId, organizationId])
}

model Follow {
  userId         Int
  organizationId Int
  followedAt     DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@id([userId, organizationId])
}

model Event {
  id             Int          @id @default(autoincrement())
  title          String
  startDateTime  DateTime
  location       String
  color          String?
  createdAt      DateTime     @default(now())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Announcement {
  id             Int          @id @default(autoincrement())
  title          String
  body           String
  color          String?
  createdAt      DateTime     @default(now())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model ClubRequest {
  id              Int      @id @default(autoincrement())
  userId          Int
  clubName        String
  description     String
  location        String
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedById    Int?
  user            User     @relation(fields: [userId], references: [id])
  reviewedBy      User?    @relation("ClubRequestReviewer", fields: [reviewedById], references: [id])
}